{
  "name": "text-summarizer",
  "version": "1.0.0",
  "description": "Summarize any text to a configurable length",
  "capabilities": ["summarization", "nlp"],
  "inputs": {
    "text": { "type": "string", "required": true, "description": "The text to summarize" },
    "maxLength": { "type": "number", "default": 200, "description": "Maximum character length of the summary" }
  },
  "outputs": {
    "summary": { "type": "string", "description": "The summarized text" }
  },
  "pricing": {
    "price": "0.01",
    "currency": "USDC",
    "per": "request"
  },
  "endpoint": "https://my-agent.example.com/v1",
  "inkd": {
    "projectId": 0,
    "owner": "0x0000000000000000000000000000000000000000"
  }
}
